Cell[CellGroupData[{

Cell["Density Comparison: HS vs Gaussian Gas", "Title",ExpressionUUID->"a1b2c3d4-1234-5678-abcd-ef0123456789"],

Cell["\<\
Compares logQ(N,V,T) for Hard Sphere and Gaussian Gas at increasing density. \
At low density both systems look ideal; virial corrections diverge with N at \
higher density, making the two potentials clearly distinguishable. Uses \
configIntegral (defined in Hard Sphere section), bClusterAbs (HS absolute \
cluster integrals), and bClusterGG (GG absolute cluster integrals, already in \
sigma^3 units). Lambda=1 for both.\
\>", "Text",ExpressionUUID->"b2c3d4e5-2345-6789-bcde-f01234567890"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Density", " ", "comparison", ":", " ", "HS", " ", "vs", " ", "GG", " ", 
    "logQ", " ", "at", " ", "several", " ", "box", " ", "sizes"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Requires", ":", " ", "configIntegral"}], ",", " ", 
    RowBox[{"bClusterAbs", " ", "(", "HS", ")"}], ",", " ", 
    RowBox[{"bClusterGG", " ", 
     RowBox[{"(", "GG", ")"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"NcompMax", "=", "12"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", 
    "\"\<L(\[Sigma])  V         \[Rho]_max    logQ_HS[12]     logQ_GG[12]     \
\[CapitalDelta]\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Vcomp", "=", 
         RowBox[{"boxL", "^", "3"}]}], ";"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"rhoComp", "=", 
         RowBox[{"(", 
          RowBox[{"NcompMax", "/", "Vcomp"}], ")"}]}], ";"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ZHScomp", "=", 
         RowBox[{"configIntegral", "[", 
          RowBox[{"NcompMax", ",", "Vcomp", ",", "bClusterAbs"}], "]"}]}], 
        ";"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ZGGcomp", "=", 
         RowBox[{"configIntegral", "[", 
          RowBox[{"NcompMax", ",", "Vcomp", ",", "bClusterGG"}], "]"}]}], 
        ";"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"lHS12", "=", 
         RowBox[{"Log", "[", 
          RowBox[{"ZHScomp", "[", 
           RowBox[{"[", "NcompMax", "]"}], "]"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"lGG12", "=", 
         RowBox[{"Log", "[", 
          RowBox[{"ZGGcomp", "[", 
           RowBox[{"[", "NcompMax", "]"}], "]"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"boxL", ",", "\"\<   \>\"", ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{"Vcomp", ",", 
           RowBox[{"{", 
            RowBox[{"7", ",", "1"}], "}"}]}], "]"}], ",", "\"\<   \>\"", ",", 
         
         RowBox[{"NumberForm", "[", 
          RowBox[{"rhoComp", ",", 
           RowBox[{"{", 
            RowBox[{"6", ",", "4"}], "}"}]}], "]"}], ",", "\"\<   \>\"", ",", 
         
         RowBox[{"NumberForm", "[", 
          RowBox[{"lHS12", ",", 
           RowBox[{"{", 
            RowBox[{"12", ",", "6"}], "}"}]}], "]"}], ",", "\"\<   \>\"", ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{"lGG12", ",", 
           RowBox[{"{", 
            RowBox[{"12", ",", "6"}], "}"}]}], "]"}], ",", "\"\<   \>\"", ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{
           RowBox[{"lHS12", "-", "lGG12"}], ",", 
           RowBox[{"{", 
            RowBox[{"8", ",", "5"}], "}"}]}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"boxL", ",", 
        RowBox[{"{", 
         RowBox[{
         "20.0`", ",", "15.0`", ",", "12.0`", ",", "10.0`", ",", "8.0`", ",", 
          "7.0`", ",", "6.0`", ",", "5.5`", ",", "5.0`"}], "}"}]}], "}"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Detailed", " ", "logQ", " ", "at", " ", "L"}], "=", 
     RowBox[{"7", " ", "for", " ", "runtests", 
      RowBox[{".", "jl"}], " ", "reference", " ", "values"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"V7comp", "=", 
     RowBox[{"7.0`", "^", "3"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ZHS7", "=", 
     RowBox[{"configIntegral", "[", 
      RowBox[{"NcompMax", ",", "V7comp", ",", "bClusterAbs"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ZGG7", "=", 
     RowBox[{"configIntegral", "[", 
      RowBox[{"NcompMax", ",", "V7comp", ",", "bClusterGG"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\n--- L=7 (V=343) detailed logQ ---\>\"", "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", 
    "\"\<  N    logQ_HS             logQ_GG             Delta\>\"", "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"lHS7", "=", 
         RowBox[{"Log", "[", 
          RowBox[{"ZHS7", "[", 
           RowBox[{"[", "N", "]"}], "]"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"lGG7", "=", 
         RowBox[{"Log", "[", 
          RowBox[{"ZGG7", "[", 
           RowBox[{"[", "N", "]"}], "]"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  \>\"", ",", "N", ",", "\"\<   \>\"", ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{"lHS7", ",", 
           RowBox[{"{", 
            RowBox[{"16", ",", "10"}], "}"}]}], "]"}], ",", "\"\<   \>\"", 
         ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{"lGG7", ",", 
           RowBox[{"{", 
            RowBox[{"16", ",", "10"}], "}"}]}], "]"}], ",", "\"\<   \>\"", 
         ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{
           RowBox[{"lHS7", "-", "lGG7"}], ",", 
           RowBox[{"{", 
            RowBox[{"12", ",", "8"}], "}"}]}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"N", ",", "1", ",", "NcompMax"}], "}"}]}], "]"}], 
    ";"}]}]}]], "Input",
 CellLabel->
  "In[445]:=",ExpressionUUID->"c3d4e5f6-3456-789a-cdef-012345678901"],

