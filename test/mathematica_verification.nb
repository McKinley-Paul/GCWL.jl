Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Gaussian", " ", "Gas", ":", " ", 
    RowBox[{"Ushcats", " ", "recursion", " ", "\[Rule]", " ", 
     RowBox[{"logQ", "(", 
      RowBox[{"N", ",", "V", ",", "T"}], ")"}], " ", "from", " ", "Koning", 
     " ", "2016", " ", "virials"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"b", " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Pi]", " ", 
        SuperscriptBox["\[Sigma]", "2"]}], ")"}], 
      RowBox[{"3", "/", "2"}]], " ", "with", " ", "\[Sigma]", "=", "1"}]}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"bRef", "=", 
     RowBox[{"0.5`", " ", 
      SuperscriptBox["\[Pi]", 
       RowBox[{"3", "/", "2"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nMaxGG", "=", 
     RowBox[{"Length", "[", "BTildes", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Absolute", " ", "virial", " ", "coefficients", ":", " ", 
     RowBox[{"B_n", " ", "=", " ", 
      RowBox[{
       RowBox[{"BTilde_n", " ", "*", " ", "b", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}], ";", " ", 
       RowBox[{"stored", " ", "as", " ", 
        RowBox[{"BnGG", "[", "[", 
         RowBox[{"i", "]"}], "]"}], " ", "=", " ", 
        RowBox[{"B_", 
         RowBox[{"(", 
          RowBox[{"i", "+", "1"}], ")"}]}]}]}]}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"BnGG", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"BTildes", "[", 
         RowBox[{"[", "n", "]"}], "]"}], " ", 
        SuperscriptBox["bRef", "n"]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "nMaxGG"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<B2 = \>\"", ",", 
     RowBox[{"BnGG", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<   B3 = \>\"", ",", 
     RowBox[{"BnGG", "[", 
      RowBox[{"[", "2", "]"}], "]"}], ",", "\"\<   B4 = \>\"", ",", 
     RowBox[{"BnGG", "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Step", " ", "1", ":", " ", 
     RowBox[{
     "Irreducible", " ", "cluster", " ", "integrals", " ", "\[Beta]_l", " ", 
      "=", " ", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"B_", 
         RowBox[{"(", 
          RowBox[{"l", "+", "1"}], ")"}]}]}], "/", 
       RowBox[{"(", 
        RowBox[{"l", "+", "1"}], ")"}]}]}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]GG", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{"BnGG", "[", 
          RowBox[{"[", "l", "]"}], "]"}]}], "/", 
        RowBox[{"(", 
         RowBox[{"l", "+", "1"}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", 
         RowBox[{"nMaxGG", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Step", " ", "2", ":", " ", 
     RowBox[{
     "Cluster", " ", "integrals", " ", "via", " ", "recursion", ":", " ", 
      RowBox[{
       RowBox[{"b_", "1"}], "=", "1"}], ",", " ", 
      RowBox[{"b_l", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "l"}], ")"}], 
        RowBox[{"\[Sum]", 
         RowBox[{"k", " ", 
          RowBox[{"\[Beta]_k", " ", "b_", 
           RowBox[{"(", 
            RowBox[{"l", "-", "k"}], ")"}]}]}]}]}]}]}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bClusterGG", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0.0`", ",", "nMaxGG"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"bClusterGG", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"bClusterGG", "[", 
         RowBox[{"[", "l", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "l"}], ")"}], 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"k", " ", 
            RowBox[{"\[Beta]GG", "[", 
             RowBox[{"[", "k", "]"}], "]"}], " ", 
            RowBox[{"bClusterGG", "[", 
             RowBox[{"[", 
              RowBox[{"l", "-", "k"}], "]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", 
             RowBox[{"Min", "[", 
              RowBox[{
               RowBox[{"l", "-", "1"}], ",", 
               RowBox[{"Length", "[", "\[Beta]GG", "]"}]}], "]"}]}], "}"}]}], 
          "]"}]}]}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "2", ",", "nMaxGG"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Step", " ", "3", ":", " ", 
     RowBox[{
     "Ushcats", " ", "recursion", " ", "and", " ", "physical", " ", 
      "parameters"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Lambda]GG", "=", "1.0`"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"boxLGG", "=", "20.0`"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"VGG", "=", 
     SuperscriptBox["boxLGG", "3"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NGasMax", "=", "12"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ZGG", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"NGasMax", "+", "1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ZGG", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ZGG", "[", 
         RowBox[{"[", 
          RowBox[{"i", "+", "1"}], "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"VGG", "/", "i"}], ")"}], 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"n", " ", 
            RowBox[{"bClusterGG", "[", 
             RowBox[{"[", "n", "]"}], "]"}], " ", 
            RowBox[{"ZGG", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"i", "-", "n"}], "+", "1"}], "]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "1", ",", 
             RowBox[{"Min", "[", 
              RowBox[{"i", ",", "nMaxGG"}], "]"}]}], "}"}]}], "]"}]}]}], 
       ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "NGasMax"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ZNdataGG", "=", 
     RowBox[{"ZGG", "[", 
      RowBox[{"[", 
       RowBox[{"2", ";;", 
        RowBox[{"NGasMax", "+", "1"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"logQ", "(", 
      RowBox[{"N", ",", "V", ",", "T"}], ")"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"ln", " ", "Z_N"}], " ", "-", " ", 
      RowBox[{"3", "N", " ", "ln", " ", "\[Lambda]"}], "  ", 
      RowBox[{"(", 
       RowBox[{"Ushcats", " ", "Z_N", " ", "already", " ", "encodes", " ", 
        RowBox[{"1", "/", 
         RowBox[{"N", "!"}]}], " ", "factor"}], ")"}]}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lnQGG", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"ZNdataGG", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], "-", 
        RowBox[{"3", " ", "i", " ", 
         RowBox[{"Log", "[", "\[Lambda]GG", "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "NGasMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", 
    "\"\<\\nln Q(N,V,T) = ln Z_N - 3N ln \[Lambda]  (Gaussian Gas, \
\[Lambda]=1, L=20, \[Sigma]=1):\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  N = \>\"", ",", "i", ",", "\"\<:  ln Q = \>\"", ",", 
        RowBox[{"lnQGG", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "NGasMax"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Verification", ":", " ", 
     RowBox[{"recover", " ", "B_n", " ", "from", " ", "\[Beta]_l"}]}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\nVerification: B_n recovered from \[Beta]_l:\>\"", 
    "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  B\>\"", ",", 
        RowBox[{"l", "+", "1"}], ",", "\"\< : input = \>\"", ",", 
        RowBox[{"BnGG", "[", 
         RowBox[{"[", "l", "]"}], "]"}], ",", "\"\<  recovered = \>\"", ",", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"l", "+", "1"}], ")"}]}], " ", 
         RowBox[{"\[Beta]GG", "[", 
          RowBox[{"[", "l", "]"}], "]"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "1", ",", 
        RowBox[{"Length", "[", "\[Beta]GG", "]"}]}], "}"}]}], "]"}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.985125*^9, 3.9851251*^9}, {3.98513252029358*^9, 
  3.985132528424692*^9}, {3.985132585868354*^9, 3.985132587386129*^9}},
 CellLabel->
  "In[424]:=",ExpressionUUID->"a1b2c3d4-e5f6-7890-abcd-ef1234567891"],

