Cell[TextData[{
 StyleBox["So for our first physics Test ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"ln", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["Q", "TI"], 
             RowBox[{"(", 
               RowBox[{
                 StyleBox["N", "TI"], "\[LongEqual]", "1", ",", "\[Lambda]", 
                 "\[LongEqual]", "0|", 
                 StyleBox["V", "TI"], ",", 
                 SuperscriptBox[
                  StyleBox["T", "TI"], "*"], "\[LongEqual]", "1"}], ")"}], 
             "\[LongEqual]", "14.055"}]}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\ln(Q(N=1,\\lambda=0|V,T^*=1)=14.055", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"981da8e8-47e6-4f90-a9da-4fff5089a567"],
 StyleBox[" within some monte carlo sampling error",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.974394144829544*^9, 3.9743941519875307`*^9}, {
  3.974394184698951*^9, 
  3.974394189062779*^9}},ExpressionUUID->"66192bc8-0511-43c5-ba9a-\
9d303fa6cebc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Q(N=2|V,T) test", "Section",
 CellChangeTimes->{{3.9743939847497997`*^9, 3.97439398646297*^9}, {
  3.9743962574926853`*^9, 
  3.974396274236364*^9}},ExpressionUUID->"446444dd-3514-4fbe-bcf7-\
f0e223d6e8b5"],

Cell[TextData[{
 "Although Q(N=2) cannot be solved for directly, we can indirectly find the \
analytic value for it using some thermodynamic relations in the \
infinite/large volume limit (or we could probably just numerically integrate \
it with a grid or quadrature for any volume). \n\n\tFirst we define the mayer \
f-function: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            StyleBox["u", "TI"], 
            RowBox[{"(", 
              SubscriptBox[
               StyleBox["r", "TI"], 
               RowBox[{
                 StyleBox["i", "TI"], 
                 StyleBox["j", "TI"]}]], ")"}]}]], "-", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f_{ij}=e^{-\\beta u(r_{ij})}-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0f898aa5-05a9-45ad-97be-a68a75b76c71"],
 ".  where u(rij) is the two particle interaction potential, which for us is \
the Lennard jones potential. Following R.K. Pathria and Paul D. Beale\
\[CloseCurlyQuote]s Third edition of ",
 StyleBox["Statistical Mechanics",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " (2011) ",
 StyleBox["Chapter 10: Statistical Mechanics of Interacting Systems",
  FontSlant->"Italic"],
 " page 304: we look at the second cluster integral ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["b", "TI"], "2"], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{"2", 
            SuperscriptBox["\[Lambda]", "3"], 
            StyleBox["V", "TI"]}]], "\[Integral]", "\[Integral]", 
         SubscriptBox[
          StyleBox["f", "TI"], "12"], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "b_2 = \\frac{1}{2 \\lambda^3 V} \\int \\int f_{12}d^3r_1d^3r_2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eb06f58a-e14b-40d8-9748-ace06c00e277"],
 " and switch variables to integrate over ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["r", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "r_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f96432ea-1406-466c-bdf0-1f4f69ba5467"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["r", "TI"], "2"], "-", 
         SubscriptBox[
          StyleBox["r", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r = r_2 -r_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0fd8d693-ed7e-4cf6-8344-5c31013544fe"],
 ": ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["b", "TI"], "2"], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{"2", 
            SuperscriptBox["\[Lambda]", "3"], 
            StyleBox["V", "TI"]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], "\[Integral]", 
         SubscriptBox[
          StyleBox["f", "TI"], "12"], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "b_2 = \\frac{1}{2 \\lambda^3 V} \\int d^3r_1 \\int f_{12}d^3r", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d28f5fa-90a4-4b1e-b483-028c5424fda8"],
 " recognizing that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], "\[LongEqual]", 
         StyleBox["V", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\int d^3r_1=V", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5dfa663e-21ba-450a-a89e-b7908abeb485"],
 " and switching to a shell integral and integrating over the angular terms: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["b", "TI"], "2"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[Pi]"}], 
          SuperscriptBox["\[Lambda]", "3"]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SubscriptBox[
          StyleBox["f", "TI"], "12"], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "b_2 = \\frac{2 \\pi}{ \\lambda^3 }  \\int_0^\\infty f_{12}r^2dr}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "79cd2fbf-c058-442f-9127-03b532528c5a"],
 " (eqn 10.1.18). Now technically this integral depends on V because r12 is \
bounded by the finite volume of the system (which we well know in the context \
of this manuscript!!), but if V is large, we can assume the mayer function \
decays to zero before the wall is reached and thus set our bounds of \
integration to be 0 and infinity. For the lennard jones system this can be \
analytically solved:"
}], "Text",
 CellChangeTimes->{{3.974396280092744*^9, 3.974396331854681*^9}, {
  3.9743969978460407`*^9, 3.974397053812929*^9}, {3.974471311813821*^9, 
  3.974471362860125*^9}, {3.974471544867219*^9, 3.974471592213641*^9}, {
  3.9744716633725233`*^9, 3.9744717703774633`*^9}, {3.974471800685164*^9, 
  3.974471877968965*^9}, {3.974471923679059*^9, 3.9744719331518307`*^9}, {
  3.974471965087802*^9, 3.974472052653054*^9}, {3.9744720832460117`*^9, 
  3.974472106396331*^9}, {3.974472157407305*^9, 3.974472266632207*^9}, {
  3.974472925789259*^9, 3.974472933897999*^9}, {3.974473759361351*^9, 
  3.9744737594277687`*^9}},ExpressionUUID->"01c3daec-8974-45d9-b977-\
fdbea7ff9992"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "you", " ", "have", " ", "to", " ", "restart", " ", "the", " ", "notebook",
     " ", "kernel", " ", "before", " ", "running", " ", "this", " ", "for", 
    " ", "some", " ", "reason"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"int", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"r", "^", "2"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "4"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"1", "/", 
             RowBox[{"r", "^", "12"}]}], "-", 
            RowBox[{"1", "/", 
             RowBox[{"r", "^", "6"}]}]}], ")"}]}], "]"}], "-", "1"}], ")"}]}],
      ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9744722763496857`*^9, 3.9744723025422583`*^9}, {
  3.974472334723465*^9, 3.974472429643285*^9}, {3.9744725452872953`*^9, 
  3.974472736061027*^9}, {3.974472837109424*^9, 
  3.974472848956608*^9}},ExpressionUUID->"844962a9-04ef-4b77-9608-\
ecf4d11fc0fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox["1", "3"]}], " ", 
  SqrtBox[
   FractionBox["\[ExponentialE]", "2"]], " ", "\[Pi]", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"BesselI", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["5", "4"]}], ",", 
      FractionBox["1", "2"]}], "]"}], "+", 
    RowBox[{"BesselI", "[", 
     RowBox[{
      FractionBox["5", "4"], ",", 
      FractionBox["1", "2"]}], "]"}]}], ")"}]}]], "Output",
 CellChangeTimes->{
  3.974472430161934*^9, {3.974472558438464*^9, 3.974472559662178*^9}, 
   3.974472630339079*^9, 3.9744726753023157`*^9, {3.9744727085104847`*^9, 
   3.974472736796007*^9}, 3.974472831805998*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"c30339c7-d942-4481-a6e5-aec0e6f57905"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalLambda]", " ", "=", " ", "0.07509097762269842"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"for", " ", "argon_deBroglie", " ", "at", " ", "T"}], "*=", "1"}],
    " ", "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"b2", " ", "=", " ", 
  RowBox[{
   FractionBox[
    RowBox[{"2", "*", "\[Pi]"}], 
    RowBox[{"\[CapitalLambda]", " "}]], "*", "int"}]}]}], "Input",
 CellChangeTimes->{{3.974472857621565*^9, 3.9744729049355803`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"ab7969b7-23b9-48a5-94c4-1219e64833fc"],

Cell[BoxData["70.79072997254384`"], "Output",
 CellChangeTimes->{{3.974472877578032*^9, 3.974472905411579*^9}},
 CellLabel->"Out[5]=",ExpressionUUID->"b288adba-c853-4bd6-8c6c-4f9d9af8045f"]
}, Open  ]],

Cell[TextData[{
 "Now, we can examining the relation between the cluster integrals and the",
 StyleBox[" ",
  FontSlant->"Italic"],
 "partition function Q by Pathria Beale equation (10.1.29):\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], 
             StyleBox["V", "TI"], 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{"{", 
            SubscriptBox[
             StyleBox["m", "TI"], 
             StyleBox["l", "TI"]], "}"}], "\[Prime]", LimitsPositioning -> 
          True], 
         RowBox[{"[", 
           RowBox[{
             UnderoverscriptBox["\[Product]", 
              RowBox[{
                StyleBox["l", "TI"], "\[LongEqual]", "1"}], 
              StyleBox["N", "TI"], LimitsPositioning -> True], 
             RowBox[{"{", 
               RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                    RowBox[{
                    SubscriptBox[
                    StyleBox["b", "TI"], 
                    StyleBox["l", "TI"]], 
                    FractionBox[
                    StyleBox["V", "TI"], 
                    SuperscriptBox["\[Lambda]", "3"]]}], ")"}], 
                  SubscriptBox[
                   StyleBox["m", "TI"], 
                   StyleBox["l", "TI"]]], 
                 FractionBox["1", 
                  RowBox[{
                    SubscriptBox[
                    StyleBox["m", "TI"], 
                    StyleBox["l", "TI"]], "!"}]]}], "}"}]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "Q(NVT) = \\sum'_{\\{m_l\\}} [ \\prod_{l=1}^N \\{  (b_l \
\\frac{V}{\\lambda^3})^{m_l} \\frac{1}{m_l!}  \\}]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "52ffd0be-696c-4013-a4eb-5b6cd22fa97c"],
 "\nwhich for the simple case of N=2 we have ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"{", 
           SubscriptBox[
            StyleBox["m", "TI"], 
            StyleBox["l", "TI"]], "}"}], "\[LongEqual]", 
         RowBox[{"{", 
           RowBox[{"2", ",", "0"}], "}"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\{m_l\\} = \\{2,0\\}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7ef4430d-97af-4e66-9fa1-db325fa2fe82"],
 " or ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"{", 
           SubscriptBox[
            StyleBox["m", "TI"], 
            StyleBox["l", "TI"]], "}"}], "\[LongEqual]", 
         RowBox[{"{", 
           RowBox[{"0", ",", "1"}], "}"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\{m_l\\} = \\{0,1\\}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49ac4509-6b17-40d1-8a24-c5262a100c9b"],
 " , and taking into account the fact that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["b", "TI"], "1"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b_1=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5b16ab63-a18d-497b-ba2a-ca164dc62638"],
 " from (10.1.17) thus the general expression above becomes: ",
 "\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], "\[LongEqual]", "2|", 
             StyleBox["V", "TI"], "\[Rule]", "\[Infinity]", ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["V", "TI"], "2"], 
          RowBox[{"2", 
            SuperscriptBox["\[Lambda]", "6"]}]], "+", 
         SubscriptBox[
          StyleBox["b", "TI"], "2"], 
         FractionBox[
          StyleBox["V", "TI"], 
          SuperscriptBox["\[Lambda]", "3"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "Q(N=2|V \\to \\infty,T) = \\frac{V^2}{2\\lambda^6} + b_2 \
\\frac{V}{\\lambda^3}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"517a1b0e-8880-450d-8b16-40a416881734"],
 "\n\ngiving us an analytic expression for Q(N=2|V,T) assuming V is large \
enough for the simplifications we made computing the integral of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["b", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "b_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91ef26fc-45c2-4231-b428-9005cedda028"],
 " to be valid. It is interesting to note that the periodic boundary \
conditions with minimum image condition of our simulation do not seem to \
impact the thermodynamics and give, to monte carlo/numerical error, the same \
result as our analytic prediction. "
}], "Text",
 CellChangeTimes->{{3.974472955395853*^9, 3.974472958670328*^9}, {
  3.974473111246191*^9, 3.974473179327413*^9}, {3.974473214978948*^9, 
  3.974473379203896*^9}, {3.9744735446825542`*^9, 3.9744736502301702`*^9}, {
  3.9744745832841387`*^9, 3.974474652672171*^9}, {3.974474731861874*^9, 
  3.9744747832139997`*^9}, {3.97447507522827*^9, 3.9744751131292343`*^9}, {
  3.974475204119698*^9, 3.974475207733272*^9}, {3.974475273431017*^9, 
  3.974475295716486*^9}, {3.974475389806065*^9, 
  3.974475472805388*^9}},ExpressionUUID->"b8656a45-7668-4cdf-8574-\
803c89982cb6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"V", " ", "=", " ", 
   RowBox[{"8", "^", "3"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalLambda]", " ", "=", " ", "0.07509097762269842"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"QN2", " ", "=", " ", 
  RowBox[{
   FractionBox[
    SuperscriptBox["V", "2"], 
    RowBox[{"2", "*", 
     SuperscriptBox["\[CapitalLambda]", "6"]}]], " ", "+", " ", 
   RowBox[{"b2", "*", 
    FractionBox["V", 
     SuperscriptBox["\[CapitalLambda]", "3"]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Log", "[", "QN2", "]"}]}], "Input",
 CellChangeTimes->{{3.974475297475416*^9, 3.974475379658964*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"02c157bd-9428-43d9-a74c-3b4458b42a8c"],

Cell[BoxData["7.311966977711167`*^11"], "Output",
 CellChangeTimes->{{3.9744753662898817`*^9, 3.974475380194249*^9}},
 CellLabel->"Out[14]=",ExpressionUUID->"8d0ba734-1983-4be7-9a81-a6952671faa3"],

Cell[BoxData["27.317948340898795`"], "Output",
 CellChangeTimes->{{3.9744753662898817`*^9, 3.974475380195056*^9}},
 CellLabel->"Out[15]=",ExpressionUUID->"15542cc7-ff88-4c05-b8f9-624da3622bf7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Ideal Gas Partition Function at high temperature limit", "Section",
 CellChangeTimes->{{3.97447675145295*^9, 3.97447678160363*^9}, {
  3.97447707631595*^9, 
  3.9744770766024323`*^9}},ExpressionUUID->"4844dadc-6608-4ea6-936f-\
7886c12ca010"],

Cell[TextData[{
 "In the high temperature limit, our system should become the ideal gas.  The \
ideal gas partition can be written:\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{
            StyleBox["N", "TI"], "!"}]], 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             StyleBox["V", "TI"], 
             SuperscriptBox["\[Lambda]", "3"]], ")"}], 
          StyleBox["N", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "Q(N,V,T) = \\frac{1}{N!} (\\frac{V}{\\lambda^3})^N", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c71d3c52-ef2a-42c2-baa7-974b62f41259"],
 "\n\nnow of course because ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Lambda]", "\[TildeTilde]", 
         FractionBox["1", 
          SqrtBox[
           StyleBox["T", "TI"]]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda \\approx \\frac{1}{\\sqrt{T}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "94d24787-543a-4630-8df4-bbe1a93942b8"],
 " the partition function is undefined at T=infinity thus we can expect \
numerical division by zero errors if we were to use ",
 Cell[BoxData[
  RowBox[{"T", "=", 
   RowBox[{"typemax", 
    RowBox[{"(", "Float64", ")"}]}]}]], "InlineCode",ExpressionUUID->
  "b3dc3ee3-9ffc-495f-ab6b-0ca0bf8aee70"],
 " in julia so instead we just pick a high temp and see if its close enough \
to ideal gas behavior. "
}], "Text",
 CellChangeTimes->{{3.9744767558629017`*^9, 3.9744767870679617`*^9}, {
  3.9744768896901083`*^9, 3.974476961442657*^9}, {3.9744770203284397`*^9, 
  3.974477023441934*^9}, {3.974477071353078*^9, 3.974477096109675*^9}, {
  3.974477144508922*^9, 3.9744771738891277`*^9}, {3.974477257782341*^9, 
  3.9744773724701643`*^9}},ExpressionUUID->"31098741-2734-4d78-b40f-\
d70560c81c01"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"TLJ", " ", "=", " ", "1000000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"h", " ", "=", " ", 
   RowBox[{"6.62607015", "\[Times]", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "34"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kB", " ", "=", " ", 
   RowBox[{"1.380649", "\[Times]", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"\[Minus]", "23"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mkg", " ", "=", " ", 
   RowBox[{"39.948", "*", "1.66054", "*", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "27"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Epsilon]", " ", "=", " ", 
   RowBox[{"117.05", "*", "kB"}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TK", " ", "=", " ", 
   RowBox[{"\[Epsilon]", "*", 
    RowBox[{"TLJ", "/", "kB"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalLambda]", "=", 
    FractionBox["h", 
     SqrtBox[
      RowBox[{"2", "*", "\[Pi]", "*", "mkg", "*", "kB", "*", "TK"}]]]}], 
   ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"in", " ", "meters"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Sigma]A", "=", "3.4"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"in", " ", "angstroms"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"\[CapitalLambda]LJ", "=", 
  FractionBox[
   RowBox[{"\[CapitalLambda]", "*", 
    SuperscriptBox["10", "10"]}], "3.4"], " ", 
  RowBox[{"(*", 
   RowBox[{
   "thermal", " ", "wavelength", " ", "of", " ", "argon", " ", "in", " ", 
    "lennard", " ", "jones", " ", "units"}], " ", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.974477475954216*^9, 
  3.974477579547707*^9}},ExpressionUUID->"041bedca-ea0d-4edd-af50-\
b0a37c0eeb41"],

Cell[BoxData["0.00007509095651813958`"], "Output",
 CellChangeTimes->{{3.9744774837037582`*^9, 3.974477510726996*^9}, 
   3.974477556351616*^9},
 CellLabel->"Out[51]=",ExpressionUUID->"b7fda9b5-2f55-4020-8d1a-728e3f4b4ab7"]
}, Open  ]],

Cell[BoxData[
 FormBox["", TraditionalForm]], "Input",
 CellChangeTimes->{
  3.974477994476598*^9},ExpressionUUID->"595bcd90-ca39-48ec-8b3d-\
860f3743b37c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Q", "[", 
   RowBox[{"N_", ",", "V_", ",", "\[CapitalLambda]_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"N", "!"}]], 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox["V", 
      SuperscriptBox["\[CapitalLambda]", "3"]], ")"}], 
    "N"]}]}], "\[IndentingNewLine]", 
 RowBox[{"Log", "[", 
