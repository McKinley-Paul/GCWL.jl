Cell[CellGroupData[{

Cell["Gaussian Gas", "Title",
 CellChangeTimes->{{3.985124135624687*^9, 
  3.985124136867427*^9}},ExpressionUUID->"c18215cf-8699-476c-ba48-\
586a8ba91c78"],

Cell[TextData[{
 "Gaussian gas is a great test case because it\[CloseCurlyQuote]s virial\
\[CloseCurlyQuote]s are analytically computable once all the biconnected \
graphs are generated and Koning 2016 computed analytically the first 13 \
virials via brute force generation of graphs (J. Chem. Phys. 145, 194101 \
(2016) https://doi.org/10.1063/1.4967775) The gaussian gas has mayer function \
given by their equation (7)\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", "-", "exp", 
         RowBox[{"[", 
           RowBox[{"-", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 StyleBox["r", "TI"], "\[Sigma]"], ")"}], "2"]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(r) = -\\exp[-(\\frac{r}{\\sigma})^2]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "82ebe324-bd2b-4a36-afb3-8119461f3698"],
 " \n\nwith interatomic pair potential given by their equation (8) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["U", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         FractionBox["-1", "\[Beta]"], "ln", 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], "\[Sigma]"], ")"}], "2"]}]]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "U(r) = \\frac{-1}{\\beta}\\ln(1-e^{-(\\frac{r}{\\sigma})^2})", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "59c1cc0f-0003-41be-af01-a1cc57a9caae"],
 " \n. They define in equation (10) \n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "\[LongEqual]", "1", "/", "2", 
         SuperscriptBox[
          RowBox[{"(", 
            SuperscriptBox["\[Pi]\[Sigma]", "2"], ")"}], 
          RowBox[{"3", "/", "2"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "b = 1/2 (\\pi \\sigma^2)^{3/2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ec12a2cd-7f1f-40b6-affc-d6a8dcf66efd"],
 " \n .Which they then use to define the virial coefficients in terms of \
reduced ones in equation (14)\n \n  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["B", "TI"], 
          StyleBox["n", "TI"]], "\[LongEqual]", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["B", "TI"], "~"], 
          StyleBox["n", "TI"]], 
         SuperscriptBox[
          StyleBox["b", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "B_n = \\tilde{B}_n b^{n-1}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c127f5c5-4a5b-400e-806a-f9d0700dcf46"],
 "\n  \n  which they define in terms of the virial expansion in equation (15)\
\n  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Beta]", 
         StyleBox["P", "TI"], "\[LongEqual]", "\[Rho]", "+", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["n", "TI"], "\[LongEqual]", "2"}], "\[Infinity]", 
          LimitsPositioning -> True], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["B", "TI"], "~"], 
          StyleBox["n", "TI"]], 
         SuperscriptBox[
          StyleBox["b", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], 
         SuperscriptBox["\[Rho]", 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta P = \\rho + \\sum_{n=2}^\\infty \\tilde{B}_n b^{n-1}\\rho^n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e18a5f7e-c2a6-49cf-9c37-fd02a9ad6341"]
}], "Text",
 CellChangeTimes->{{3.985124137681345*^9, 3.985124220425486*^9}, {
   3.9851245403018713`*^9, 3.985124580670073*^9}, {3.985124638000033*^9, 
   3.985124650178369*^9}, {3.985124687862783*^9, 3.9851247032934427`*^9}, 
   3.9851247553435993`*^9, {3.985124807312211*^9, 
   3.9851249164764967`*^9}},ExpressionUUID->"b3e4d8f8-801b-4109-aecb-\
adc9bc915129"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BTildes", " ", "=", " ", 
  RowBox[{"{", 
   RowBox[{"1", ",", " ", "0.25660011963983367311", ",", 
    RowBox[{"-", "0.12545995705504467834"}], ",", " ", 
    "0.01332565517320544100", ",", " ", "0.03846093583086967155", ",", 
    RowBox[{"-", "0.03308344290314971739"}], ",", " ", 
    "0.00418241876968238735", ",", " ", "0.01519760719550087466", ",", 
    RowBox[{"-", "0.01384965413457514293"}], ",", " ", 
    "0.00133475791711096611", ",", "0.00760432724881212587", ",", " ", 
    RowBox[{"-", "0.00672644140878158825"}]}], "}"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "From", " ", "table", " ", "1", " ", "of", " ", "Koning", " ", "2016"}], 
    ",", " ", 
    RowBox[{
     RowBox[{"starts", " ", "from", " ", "n"}], "=", 
     RowBox[{
      RowBox[{"2", " ", "and", " ", "goes", " ", "to", " ", "n"}], "=", 
      "13"}]}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9851242234655533`*^9, 3.985124486082258*^9}},
 CellLabel->
  "In[381]:=",ExpressionUUID->"5d3a952a-e1bf-43f6-a5d6-b776ece115a9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "0.25660011963983367311`19.40925685452881", ",", 
   RowBox[{"-", "0.12545995705504467834`19.0985051345423"}], ",", 
   "0.013325655173205441`18.12468857087781", ",", 
   "0.03846093583086967155`18.585019847277348", ",", 
   RowBox[{"-", "0.03308344290314971739`18.51961069906777"}], ",", 
   "0.00418241876968238735`17.621427514913265", ",", 
