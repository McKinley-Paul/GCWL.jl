Cell[CellGroupData[{

Cell["Q(N=2,V,T) Lennard Jones", "Title",
 CellChangeTimes->{{3.9869155447478123`*^9, 
  3.986915553229918*^9}},ExpressionUUID->"b420eb35-81e6-453f-9c6a-\
7162f711beb5"],

Cell[TextData[{
 "Does Q(N=2,V,T) in the non-infinite volume limit have a closed form \
solution?\n",
 StyleBox["NO but here is the attempt:",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{
            StyleBox["N", "TI"], "!", 
            SuperscriptBox["\[CapitalLambda]", 
             RowBox[{"3", 
               StyleBox["N", "TI"]}]]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            StyleBox["H", "TI"]}]], 
         SuperscriptBox[
          StyleBox["d", "TI"], 
          RowBox[{"3", 
            StyleBox["N", "TI"]}]], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$Q(N,V,T) = \\frac{1}{N! \\Lambda^{3N}}  \\int e^{-\\beta H} d^{3N}r $",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "be7af8d2-7f35-4333-b41e-40206e2d2e60"],
 "  .   which in this situation is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], "\[LongEqual]", "2", ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{"2", 
            SuperscriptBox["\[CapitalLambda]", "6"]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            StyleBox["H", "TI"]}]], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$Q(N=2,V,T) = \\frac{1}{2 \\Lambda^{6}}  \\int e^{-\\beta H} \
d^3r_1d^3r_2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1536bedb-c9f0-46a1-8c04-d4695fe68bbe"],
 "  . perform the change of variables ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "1"], "-", 
         SubscriptBox[
          StyleBox["r", "TI"], "2"], "\[Rule]", 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r_1 - r_2 \\to r", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "35892ca8-3b50-401b-91b6-1ffca259ae4f"],
 " and you get ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], "\[LongEqual]", "2", ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          StyleBox["V", "TI"], 
          RowBox[{"2", 
            SuperscriptBox["\[CapitalLambda]", "6"]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            StyleBox["H", "TI"], 
            RowBox[{"(", 
              StyleBox["r", "TI"], ")"}]}]], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$Q(N=2,V,T) = \\frac{V}{2 \\Lambda^{6}}  \\int e^{-\\beta H(r)} d^3r$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5a25980c-7464-40c0-b730-572a0440815a"],
 "  now here we substitute in lennard jones potential for potential energy \
part of hamiltonian: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", "4", "\[Epsilon]", 
         RowBox[{"[", 
           RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox["\[Sigma]", 
                 StyleBox["r", "TI"]], ")"}], "12"], "-", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox["\[Sigma]", 
                 StyleBox["r", "TI"]], ")"}], "6"]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "V(r) = 4 \\epsilon [ (\\frac{\\sigma}{r})^{12} - \
(\\frac{\\sigma}{r})^{6} ]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f7b6e4b1-0bae-4d46-b6f3-c6069cb5dc42"],
 " or using lennard jones units ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
        "\[Epsilon]", "\[LongEqual]", "\[Sigma]", "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\epsilon = \\sigma = 1",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c57e0519-2e48-4776-b577-b446bc479aa9"],
 " this simplifies to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", "4", 
         RowBox[{"[", 
           RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox["1", 
                 StyleBox["r", "TI"]], ")"}], "12"], "-", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox["1", 
                 StyleBox["r", "TI"]], ")"}], "6"]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "V(r) = 4  [ (\\frac{1}{r})^{12} - (\\frac{1}{r})^{6} ]", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "737a3c94-f568-419e-a8c7-094108e37905"],
 "  so we plug that in and switch to a shell integral ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], "\[LongEqual]", "2", ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          StyleBox["V", "TI"], 
          RowBox[{"2", 
            SuperscriptBox["\[CapitalLambda]", "6"]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            RowBox[{"[", 
              RowBox[{"4", 
                RowBox[{"(", 
                  RowBox[{
                    SuperscriptBox[
                    RowBox[{"(", 
                    FractionBox["1", 
                    StyleBox["r", "TI"]], ")"}], "12"], "-", 
                    SuperscriptBox[
                    RowBox[{"(", 
                    FractionBox["1", 
                    StyleBox["r", "TI"]], ")"}], "6"]}], "]"}]}], ")"}]}]], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "sin", "\[Phi]", 
         StyleBox["d", "TI"], "\[Phi]", 
         StyleBox["d", "TI"], "\[Theta]", 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$Q(N=2,V,T) = \\frac{V}{2 \\Lambda^{6}}  \\int e^{-\\beta [4  \
((\\frac{1}{r})^{12} - (\\frac{1}{r})^{6} ])} r^2 \\sin \\phi d\\phi d\\theta \
dr$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e77446d5-655d-4d71-874c-bef360719ad7"],
 "  and perform the angular integrals you get a factor of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"4", "\[Pi]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "4\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "40038428-dbdb-4c8d-a644-fb2219371f37"],
 " out :\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], "\[LongEqual]", "2", ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[Pi]", 
            StyleBox["V", "TI"]}], 
          SuperscriptBox["\[CapitalLambda]", "6"]], 
         SubsuperscriptBox["\[Integral]", "0", 
          StyleBox["R", "TI"]], "exp", 
         RowBox[{"[", 
           RowBox[{"-4", "\[Beta]", 
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-12"], "-", 
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-6"]}], ")"}]}], "]"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$Q(N=2,V,T) = \\frac{ 2 \\pi V}{ \\Lambda^{6}}  \\int_0^R \
\\exp[-4\\beta (r^{-12} - r^{-6})]r^2 dr$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f3744d20-15de-44a6-8b18-4a43171dafac"],
 " where we kind of imply spherical boundary conditions here\n"
}], "Text",
 CellChangeTimes->{{3.986915562132524*^9, 3.986915656505466*^9}, {
   3.9869156923810387`*^9, 3.986915814248928*^9}, {3.986915855911048*^9, 
   3.986915884845499*^9}, {3.986915917737112*^9, 3.9869159495313873`*^9}, 
   3.986916095843548*^9, {3.986916140099968*^9, 3.986916144893718*^9}, {
   3.9869163271970882`*^9, 3.986916344469976*^9}, {3.986916553270232*^9, 
   3.9869166059441833`*^9}, {3.986917266995269*^9, 
   3.986917286722806*^9}},ExpressionUUID->"90fcb45f-49a2-4239-b660-\
f4af85364c5f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Qstar", "[", 
   RowBox[{"R_", ",", "T_"}], "]"}], " ", ":=", " ", 
  RowBox[{"2", " ", "\[Pi]", " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["4", "3"], "\[Pi]", " ", 
     SuperscriptBox["R", "3"]}], ")"}], " ", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "R"], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       FractionBox[
        RowBox[{"-", "4"}], "T"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["r", 
          RowBox[{"-", "12"}]], " ", "-", " ", 
         SuperscriptBox["r", 
          RowBox[{"-", "6"}]]}], ")"}]}]], 
     RowBox[{"\[DifferentialD]", "r"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.986916622482753*^9, 
