Cell[CellGroupData[{

Cell["Hard Sphere ", "Title",
 CellChangeTimes->{{3.985114995815465*^9, 
  3.9851149977555037`*^9}},ExpressionUUID->"a6347cf2-aa04-4a0c-9627-\
af4fe080fe4a"],

Cell[TextData[{
 "Hard sphere virial coefficients are taken form sklogwiki \
(http://www.sklogwiki.org/SklogWiki/index.php/Hard_sphere:_virial_\
coefficients). To convert to partition functions, we must first convert them \
to irreducible integrals:\n\[Beta]\:2097 = \[Minus]B\:2097\:208a\:2081 / (l + \
1)\nSo \[Beta]\:2081 = \[Minus]B\:2082/2, \[Beta]\:2082 = \[Minus]B\:2083/3, \
\[Beta]\:2083 = \[Minus]B\:2084/4, etc. \nand then to reducible integrals \
(AKA cluster integrals) \nb\:2081 = 1\nb\:2097 = (1/l) \[CapitalSigma]\:2096\
\:208c\:2081\:02e1\:207b\.b9 k \[Beta]\:2096 b\:2097\:208b\:2096    for l \
\[GreaterEqual] 2\n\nand then we can go between the cluster integrals and the",
 StyleBox[" ",
  FontSlant->"Italic"],
 "partition function Q either  by Pathria Beale equation (10.1.29):\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], 
             StyleBox["V", "TI"], 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{"{", 
            SubscriptBox[
             StyleBox["m", "TI"], 
             StyleBox["l", "TI"]], "}"}], "\[Prime]", LimitsPositioning -> 
          True], 
         RowBox[{"[", 
           RowBox[{
             UnderoverscriptBox["\[Product]", 
              RowBox[{
                StyleBox["l", "TI"], "\[LongEqual]", "1"}], 
              StyleBox["N", "TI"], LimitsPositioning -> True], 
             RowBox[{"{", 
               RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                    RowBox[{
                    SubscriptBox[
                    StyleBox["b", "TI"], 
                    StyleBox["l", "TI"]], 
                    FractionBox[
                    StyleBox["V", "TI"], 
                    SuperscriptBox["\[Lambda]", "3"]]}], ")"}], 
                  SubscriptBox[
                   StyleBox["m", "TI"], 
                   StyleBox["l", "TI"]]], 
                 FractionBox["1", 
                  RowBox[{
                    SubscriptBox[
                    StyleBox["m", "TI"], 
                    StyleBox["l", "TI"]], "!"}]]}], "}"}]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "Q(NVT) = \\sum'_{\\{m_l\\}} [ \\prod_{l=1}^N \\{  (b_l \
\\frac{V}{\\lambda^3})^{m_l} \\frac{1}{m_l!}  \\}]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ddfd2312-f1b8-4db1-a11c-880001f0b5ef"],
 "\n\nor via Ushcat\[CloseCurlyQuote]s recursion relation for the \
configuration integral Z (which he calls Q) via his equation (6) in \
10.1103/PhysRevE.98.032135 :\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["Z", "TI"], 
          StyleBox["N", "TI"]], "\[LongEqual]", 
         FractionBox[
          StyleBox["V", "TI"], 
          StyleBox["i", "TI"]], 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["n", "TI"], "\[LongEqual]", "1"}], 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         StyleBox["n", "TI"], 
         SubscriptBox[
          StyleBox["b", "TI"], 
          StyleBox["n", "TI"]], 
         SubscriptBox[
          StyleBox["Z", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], "-", 
            StyleBox["n", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "Z_N = \\frac{V}{i}\\sum_{n=1}^i n b_n Z_{i-n}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6ee97a08-e5da-4d2c-8daa-aec5c3e8e492"]
}], "Text",
 CellChangeTimes->{{3.985115264401997*^9, 3.985115324132011*^9}, {
   3.985115394247581*^9, 3.985115427560917*^9}, {3.98511550742113*^9, 
   3.985115537856923*^9}, {3.985115617316633*^9, 3.985115661330154*^9}, {
   3.985115776115638*^9, 3.985115822099332*^9}, {3.985115915009736*^9, 
   3.985115917504365*^9}, 3.985116666356852*^9, {3.985116737640012*^9, 
   3.985116775284812*^9}, {3.985116829741103*^9, 
   3.9851168298781652`*^9}},ExpressionUUID->"eec471c0-6374-469e-9f41-\
d37113e531dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "this", " ", "data", " ", "is", " ", "from", " ", "sklogwiki", " ", 
     RowBox[{"http", ":"}]}], "//", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"www", ".", "sklogwiki", ".", "org"}], "/", "SklogWiki"}], "/", 
      RowBox[{"index", ".", "php"}]}], "/", 
     RowBox[{"Hard_sphere", ":", 
      RowBox[{"_virial", "_coefficients"}]}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"B2", " ", "=", " ", "4"}], "\[IndentingNewLine]", 
   RowBox[{"Bs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"B2", ",", " ", 
      RowBox[{"0.625", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "2"}], ")"}]}], ",", 
      RowBox[{"0.2869495", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "3"}], ")"}]}], ",", " ", 
      RowBox[{"0.110252", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "4"}], ")"}]}], ",", " ", 
      RowBox[{"0.03888198", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "5"}], ")"}]}], ",", " ", 
      RowBox[{"0.01302354", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "6"}], ")"}]}], ",", 
      RowBox[{"0.0041832", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "7"}], ")"}]}], ",", " ", 
      RowBox[{"0.0013094", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "8"}], ")"}]}], ",", " ", 
      RowBox[{"0.0004035", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "9"}], ")"}]}], ",", " ", 
      RowBox[{"0.000122", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "10"}], ")"}]}], ",", " ", 
      RowBox[{"0.000027", "*", 
       RowBox[{"(", 
        RowBox[{"B2", "^", "11"}], ")"}]}]}], "  ", "}"}]}]}]}]], "Input",
 CellChangeTimes->{{3.985115928604579*^9, 3.985116113793051*^9}, {
  3.985116181808015*^9, 
  3.9851162222387323`*^9}},ExpressionUUID->"cdf7f415-ecb7-41b8-b696-\
07320fedd01e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Hard", " ", "Sphere", " ", "Virial", " ", "Coefficients", " ", "to", " ", 
    "Partition", " ", "Functions"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Virial", " ", "coefficients", " ", "from", " ", "SklogWiki"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"B2", " ", "through", " ", "B4", " ", "are", " ", "exact"}], ";", 
     RowBox[{
     "B5", " ", "through", " ", "B12", " ", "are", " ", "numerical"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Expressed", " ", "as", " ", 
      RowBox[{"Bn", "/", 
       RowBox[{"B2", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}]}], ",", 
     RowBox[{
      RowBox[{"where", " ", "B2"}], "=", 
      RowBox[{"b", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "/", "3"}], ")"}], "\[Pi]", " ", 
        RowBox[{"\[Sigma]", "^", "3"}]}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Here", " ", "we", " ", "use", " ", 
      RowBox[{"Bn", "/", 
       RowBox[{"Vsphere", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}], " ", "where", " ", "Vsphere"}], 
     "=", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "6"}], " ", 
      RowBox[{"\[Sigma]", "^", "3"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"so", " ", "B2"}], "=", 
     RowBox[{"4", " ", "Vsphere"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"B2reduced", "=", "4"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Reduced", " ", "virial", " ", "coefficients", " ", 
     RowBox[{"Bn", "/", 
      RowBox[{"B2", "^", 
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"BnOverB2nm1", "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"(*", "B2", "*)"}], "0.625", ",", 
       RowBox[{"(*", 
        RowBox[{"B3", "=", 
         RowBox[{"5", "/", "8"}]}], "*)"}], "0.28694950", ",", 
       RowBox[{"(*", "B4", "*)"}], "0.11025210", ",", 
       RowBox[{"(*", "B5", "*)"}], "0.03888198", ",", 
       RowBox[{"(*", "B6", "*)"}], "0.01302354", ",", 
       RowBox[{"(*", "B7", "*)"}], "0.0041832", ",", 
       RowBox[{"(*", "B8", "*)"}], "0.0013094", ",", 
       RowBox[{"(*", "B9", "*)"}], "0.0004035", ",", 
       RowBox[{"(*", "B10", "*)"}], "0.000122", ",", 
       RowBox[{"(*", "B11", "*)"}], "0.000027"}], "            ", 
      RowBox[{"(*", "B12", "*)"}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "BnOverB2nm1", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Construct", " ", "actual", " ", "Bn", " ", "in", " ", "units", " ", "of",
      " ", 
     RowBox[{"Vsphere", "^", 
      RowBox[{"(", 
       RowBox[{"n", "-", "1"}], ")"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Bn", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"BnOverB2nm1", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "*", 
        RowBox[{"B2reduced", "^", 
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", 
    "\"\<Virial coefficients Bn (in units of Vsphere^(n-1)):\>\"", "]"}], 
   "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  B\>\"", ",", 
        RowBox[{"n", "+", "1"}], ",", "\"\< = \>\"", ",", 
        RowBox[{"Bn", "[", 
         RowBox[{"[", "n", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "nMax"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Step", " ", "1"}], ":", "Bn"}], "->", "\[Beta]_l"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"\[Beta]", "[", "l", "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"B", "[", 
         RowBox[{"l", "+", "1"}], "]"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"l", "+", "1"}], ")"}]}], " ", 
      RowBox[{"(", 
       RowBox[{"Pathria", " ", 
        RowBox[{"eq", ".", "10.4"}], ".22"}], ")"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Bn", "[", 
          RowBox[{"[", "l", "]"}], "]"}]}], "/", 
        RowBox[{"(", 
         RowBox[{"l", "+", "1"}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", 
         RowBox[{"nMax", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\nIrreducible cluster integrals \[Beta]_l:\>\"", "]"}],
    "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  \[Beta]_\>\"", ",", "l", ",", "\"\< = \>\"", ",", 
        RowBox[{"\[Beta]", "[", 
         RowBox[{"[", "l", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "1", ",", 
        RowBox[{"Length", "[", "\[Beta]", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Step", " ", "2"}], ":", "\[Beta]_l"}], "->", "b_l"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Recursion", ":", 
      RowBox[{"b", "[", "l", "]"}]}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "l"}], ")"}], " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"k", " ", 
         RowBox[{"\[Beta]", "[", "k", "]"}], " ", 
         RowBox[{"b", "[", 
          RowBox[{"l", "-", "k"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", 
          RowBox[{"l", "-", "1"}]}], "}"}]}], "]"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"with", " ", 
      RowBox[{"b", "[", "1", "]"}]}], "=", "1"}], "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"bCluster", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0.0", ",", "nMax"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"bCluster", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"bCluster", "[", 
         RowBox[{"[", "l", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "l"}], ")"}], " ", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"k", " ", 
            RowBox[{"\[Beta]", "[", 
             RowBox[{"[", "k", "]"}], "]"}], " ", 
            RowBox[{"bCluster", "[", 
             RowBox[{"[", 
              RowBox[{"l", "-", "k"}], "]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", 
             RowBox[{"Min", "[", 
              RowBox[{
               RowBox[{"l", "-", "1"}], ",", 
               RowBox[{"Length", "[", "\[Beta]", "]"}]}], "]"}]}], "}"}]}], 
          "]"}]}]}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "2", ",", "nMax"}], "}"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\nReducible (Mayer) cluster integrals b_l:\>\"", "]"}],
    "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  b_\>\"", ",", "l", ",", "\"\< = \>\"", ",", 
        RowBox[{"ScientificForm", "[", 
         RowBox[{
          RowBox[{"bCluster", "[", 
           RowBox[{"[", "l", "]"}], "]"}], ",", "8"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "1", ",", "nMax"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "3"}], ":", 
     RowBox[{"Ushcats", " ", "recursion", " ", "for", " ", "Z_N"}]}], "*)"}], 
   
   RowBox[{
    RowBox[{"configIntegral", "[", 
     RowBox[{"Nmax_Integer", ",", "V_", ",", "bList_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Z", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Nmax", "+", "1"}]}], "]"}]}], ",", "nCluster"}], "}"}], 
      ",", 
      RowBox[{
       RowBox[{"nCluster", "=", 
        RowBox[{"Length", "[", "bList", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Z", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Z", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"V", "/", "i"}], ")"}], " ", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"n", " ", 
               RowBox[{"bList", "[", 
                RowBox[{"[", "n", "]"}], "]"}], " ", 
               RowBox[{"Z", "[", 
                RowBox[{"[", 
                 RowBox[{"i", "-", "n", "+", "1"}], "]"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"n", ",", "1", ",", 
                RowBox[{"Min", "[", 
                 RowBox[{"i", ",", "nCluster"}], "]"}]}], "}"}]}], "]"}]}]}], 
          ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "Nmax"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Z", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;"}], "]"}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Set", " ", "physical", " ", "parameters"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[Sigma]", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Vsphere", "=", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "6"}], " ", 
      RowBox[{"\[Sigma]", "^", "3"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Lambda]", "=", "1.0"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"thermal", " ", "de", " ", "Broglie", " ", "wavelength"}], "-", 
     RowBox[{
     "set", " ", "to", " ", "match", " ", "your", " ", "simulation"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"boxL", "=", "20.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"V", "=", 
     RowBox[{"boxL", "^", "3"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"bClusterAbs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"bCluster", "[", 
         RowBox[{"[", "l", "]"}], "]"}], "*", 
        RowBox[{"Vsphere", "^", 
         RowBox[{"(", 
          RowBox[{"l", "-", "1"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Nparticles", "=", "50"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"ZN", "=", 
     RowBox[{"configIntegral", "[", 
      RowBox[{"Nparticles", ",", "V", ",", "bClusterAbs"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Full", " ", "partition", " ", 
      RowBox[{"function", ":", 
       RowBox[{"Q", 
        RowBox[{"(", 
         RowBox[{"N", ",", "V", ",", "T"}], ")"}]}]}]}], "=", 
     RowBox[{"Z_N", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"N", "!"}], " ", 
        RowBox[{"\[Lambda]", "^", 
         RowBox[{"(", 
          RowBox[{"3", "N"}], ")"}]}]}], ")"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"ln", " ", "Q", 
      RowBox[{"(", "N", ")"}]}], "=", 
     RowBox[{
      RowBox[{"ln", " ", "Z_N"}], "-", 
      RowBox[{"ln", " ", 
       RowBox[{"N", "!"}]}], "-", 
      RowBox[{"3", "N", " ", "ln", " ", "\[Lambda]"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"lnQ", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"ZN", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], "-", 
        RowBox[{"3", " ", "i", " ", 
         RowBox[{"Log", "[", "\[Lambda]", "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "Nparticles"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
   "Print", "[", "\"\<\\nln Q(N,V,T) = ln Z_N - ln N! - 3N ln \[Lambda]:\>\"",
     "]"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  N = \>\"", ",", "i", ",", "\"\<:  ln Q = \>\"", ",", 
        RowBox[{"lnQ", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Min", "[", 
         RowBox[{"20", ",", "Nparticles"}], "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "Verification", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\nVerification: Bn recovered from \[Beta]_l:\>\"", 
    "]"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"BnRecovered", "=", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"l", "+", "1"}], ")"}]}], " ", 
         RowBox[{"\[Beta]", "[", 
          RowBox[{"[", "l", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  B\>\"", ",", 
         RowBox[{"l", "+", "1"}], ",", "\"\< : input = \>\"", ",", 
         RowBox[{"Bn", "[", 
          RowBox[{"[", "l", "]"}], "]"}], ",", "\"\<  recovered = \>\"", ",", 
         "BnRecovered"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "1", ",", 
        RowBox[{"Length", "[", "\[Beta]", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Convenience", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lnQFromBn", "[", 
     RowBox[{
     "BnList_List", ",", "Vbox_", ",", "Nmax_Integer", ",", "\[Lambda]val_"}],
      "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nB", ",", "\[Beta]loc", ",", "bloc", ",", "Zloc"}], "}"}], 
      ",", 
      RowBox[{
       RowBox[{"nB", "=", 
        RowBox[{"Length", "[", "BnList", "]"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"\[Beta]loc", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"BnList", "[", 
             RowBox[{"[", "l", "]"}], "]"}]}], "/", 
           RowBox[{"(", 
            RowBox[{"l", "+", "1"}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"l", ",", "1", ",", 
            RowBox[{"nB", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"bloc", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.0", ",", "nB"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"bloc", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"bloc", "[", 
            RowBox[{"[", "l", "]"}], "]"}], "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "l"}], ")"}], " ", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"k", " ", 
               RowBox[{"\[Beta]loc", "[", 
                RowBox[{"[", "k", "]"}], "]"}], " ", 
               RowBox[{"bloc", "[", 
                RowBox[{"[", 
                 RowBox[{"l", "-", "k"}], "]"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "1", ",", 
                RowBox[{"Min", "[", 
                 RowBox[{
                  RowBox[{"l", "-", "1"}], ",", 
                  RowBox[{"Length", "[", "\[Beta]loc", "]"}]}], "]"}]}], 
               "}"}]}], "]"}]}]}], ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"l", ",", "2", ",", "nB"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Zloc", "=", 
        RowBox[{"configIntegral", "[", 
         RowBox[{"Nmax", ",", "Vbox", ",", "bloc"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Log", "[", 
           RowBox[{"Zloc", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], "-", 
          RowBox[{"3", " ", "i", " ", 
           RowBox[{"Log", "[", "\[Lambda]val", "]"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "Nmax"}], "}"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "Plot", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Range", "[", "Nparticles", "]"}], ",", "lnQ"}], "}"}], "]"}],
      ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<ln Q(N,V,T) from hard-sphere virial EOS\>\""}], 
     ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<N\>\"", ",", "\"\<ln Q\>\""}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"PointSize", "[", "0.015", "]"}]}], "}"}]}], ",", 
     RowBox[{"Joined", "->", "True"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.985116868277081*^9, 3.985116882721282*^9}, {
